# Supabase — get from https://supabase.com/dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# NEVER expose this client-side. Service role bypasses all RLS — server-only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Agent API shared secret — used to authenticate internal tool calls (x-agent-secret header)
# Generate a strong random string: openssl rand -hex 32
AGENT_SECRET=your-agent-secret

# OpenAI API key for the LangGraph AI agent
# Named REMAX_OPENAI_KEY to avoid conflicts with system-level OPENAI_API_KEY env vars
REMAX_OPENAI_KEY=sk-proj-...

# Production URL — required for AI agent tools to call internal API routes
NEXT_PUBLIC_SITE_URL=https://your-app.netlify.app
